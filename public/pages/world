<style>
/* ─── RESET & BASE ─── */
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --ink:#0e0c0a;
  --paper:#f7f4ef;
  --cream:#ede9e1;
  --border:#d8d2c6;
  --muted:#9a9286;
  --gold:#a8833a;
  --gold-pale:#f5edda;
  --kz:#1b6ca8;
  --kz-pale:#e8f2fb;
  --accent:#c0392b;
  --correct:#2e7d52;
  --correct-pale:#e8f5ee;
}

html{scroll-behavior:smooth}

body{
  font-family:'Outfit',sans-serif;
  background:var(--paper);
  color:var(--ink);
  min-height:100vh;
  line-height:1.6;
}

/* ─── HERO ─── */
.hero{
  padding:3.5rem 1.5rem 2rem;
  max-width:960px;
  margin:0 auto;
  position:relative;
}

.hero-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:0.5rem;
  font-size:0.72rem;
  font-weight:600;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--gold);
  margin-bottom:1rem;
  background:var(--gold-pale);
  border:1px solid rgba(168,131,58,0.25);
  border-radius:50px;
  padding:0.35rem 1rem;
}

.hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2.2rem,5.5vw,3.6rem);
  font-weight:700;
  line-height:1.15;
  letter-spacing:-0.01em;
  margin-bottom:0.8rem;
}

.hero h1 em{
  font-style:italic;
  color:var(--gold);
}

.hero-sub{
  font-size:1rem;
  font-weight:300;
  color:var(--muted);
  max-width:520px;
  line-height:1.6;
}

.globe-deco{
  position:absolute;
  right:2rem;
  top:2.5rem;
  width:120px;
  height:120px;
  opacity:0.06;
  pointer-events:none;
}

/* ─── COUNTRY GRID ─── */
.section{
  max-width:960px;
  margin:0 auto;
  padding:0 1.5rem 1rem;
}

.section-label{
  font-size:0.7rem;
  font-weight:600;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:1rem;
}

.country-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
  gap:0.7rem;
  margin-bottom:2rem;
}

.country-card{
  background:var(--cream);
  border:1.5px solid var(--border);
  border-radius:14px;
  padding:1rem 0.75rem;
  cursor:pointer;
  transition:all 0.22s cubic-bezier(.22,.68,0,1.2);
  text-align:center;
  user-select:none;
  position:relative;
  overflow:hidden;
}

.country-card::before{
  content:'';
  position:absolute;
  inset:0;
  background:var(--gold-pale);
  opacity:0;
  transition:opacity 0.2s;
}

.country-card:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 8px 24px rgba(168,131,58,0.15);
}

.country-card:hover::before{opacity:1}

.country-card.active{
  border-color:var(--gold);
  background:var(--gold-pale);
  transform:translateY(-3px);
  box-shadow:0 8px 24px rgba(168,131,58,0.2);
}

.country-card .flag{
  font-size:2.2rem;
  display:block;
  margin-bottom:0.4rem;
  position:relative;
  z-index:1;
  line-height:1;
}

.country-card .c-name{
  font-size:0.8rem;
  font-weight:600;
  color:var(--ink);
  position:relative;
  z-index:1;
  line-height:1.2;
}

.country-card .c-sub{
  font-size:0.68rem;
  color:var(--muted);
  font-weight:400;
  margin-top:2px;
  position:relative;
  z-index:1;
}

/* ─── DETAIL PANEL ─── */
.detail-panel{
  max-width:960px;
  margin:0 auto 2rem;
  padding:0 1.5rem;
  display:none;
}

.detail-panel.show{
  display:block;
  animation:slideIn 0.35s cubic-bezier(.22,.68,0,1.2);
}

@keyframes slideIn{
  from{opacity:0;transform:translateY(16px)}
  to{opacity:1;transform:translateY(0)}
}

.detail-inner{
  background:#fff;
  border:1.5px solid var(--border);
  border-radius:20px;
  overflow:hidden;
  box-shadow:0 4px 32px rgba(0,0,0,0.06);
}

/* Header */
.detail-header{
  padding:1.75rem 2rem 1.5rem;
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:1rem;
  background:linear-gradient(135deg,var(--cream) 0%,#fff 100%);
}

.detail-flag-name{
  display:flex;
  align-items:center;
  gap:1rem;
}

.detail-flag{
  font-size:3rem;
  line-height:1;
}

.detail-title{
  font-family:'Playfair Display',serif;
  font-size:1.6rem;
  font-weight:700;
  line-height:1.2;
  margin-bottom:0.2rem;
}

.detail-tagline{
  font-size:0.88rem;
  color:var(--muted);
  font-style:italic;
  font-family:'Playfair Display',serif;
}

.close-btn{
  width:36px;
  height:36px;
  border:1.5px solid var(--border);
  border-radius:50%;
  background:transparent;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--muted);
  flex-shrink:0;
  transition:all 0.2s;
}
.close-btn:hover{border-color:var(--ink);color:var(--ink)}
.close-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}

/* Cards row */
.detail-cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  border-bottom:1px solid var(--border);
}

.detail-card{
  padding:1.4rem 1.6rem;
  border-right:1px solid var(--border);
  transition:background 0.2s;
}
.detail-card:last-child{border-right:none}
.detail-card:hover{background:var(--cream)}

.dc-icon{
  width:36px;
  height:36px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:0.75rem;
  font-size:1.1rem;
}

.dc-title{
  font-size:0.68rem;
  font-weight:700;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:0.4rem;
}

.dc-value{
  font-size:0.88rem;
  font-weight:600;
  color:var(--ink);
  line-height:1.4;
  margin-bottom:0.3rem;
}

.dc-desc{
  font-size:0.8rem;
  color:var(--muted);
  line-height:1.45;
  font-weight:400;
}

/* Tags */
.tags-row{
  padding:1.25rem 1.6rem;
  display:flex;
  flex-wrap:wrap;
  gap:0.5rem;
  border-bottom:1px solid var(--border);
  align-items:center;
}

.tags-label{
  font-size:0.68rem;
  font-weight:700;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
  margin-right:0.3rem;
}

.tag{
  padding:0.3rem 0.8rem;
  border-radius:50px;
  font-size:0.78rem;
  font-weight:500;
  background:var(--cream);
  border:1px solid var(--border);
  color:var(--ink);
}

.tag.do{background:var(--correct-pale);border-color:rgba(46,125,82,0.3);color:var(--correct)}
.tag.dont{background:#fef0ee;border-color:rgba(192,57,43,0.3);color:var(--accent)}

/* ─── COMPARE ─── */
.compare-section{
  padding:1.5rem 1.6rem;
  background:linear-gradient(135deg,var(--kz-pale) 0%,#fff 60%);
}

.compare-title{
  display:flex;
  align-items:center;
  gap:0.6rem;
  margin-bottom:1.1rem;
}

.compare-title .kz-badge{
  font-size:1.1rem;
  line-height:1;
}

.compare-title h3{
  font-family:'Playfair Display',serif;
  font-size:1.05rem;
  font-weight:700;
  color:var(--kz);
}

.compare-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:0.6rem;
}

.compare-item{
  display:flex;
  align-items:flex-start;
  gap:0.6rem;
  padding:0.8rem 1rem;
  background:#fff;
  border:1px solid rgba(27,108,168,0.15);
  border-radius:12px;
  font-size:0.83rem;
  line-height:1.4;
  transition:all 0.2s;
}

.compare-item:hover{
  border-color:var(--kz);
  background:var(--kz-pale);
}

.compare-item .ci-icon{
  font-size:1rem;
  flex-shrink:0;
  margin-top:1px;
}

.compare-item .ci-text{
  color:var(--ink);
}

.compare-item .ci-text strong{
  display:block;
  font-weight:600;
  font-size:0.78rem;
  color:var(--kz);
  margin-bottom:2px;
  letter-spacing:0.02em;
}

/* ─── EMPTY STATE ─── */
.empty-state{
  max-width:960px;
  margin:0 auto 2rem;
  padding:0 1.5rem;
}

.empty-inner{
  border:2px dashed var(--border);
  border-radius:20px;
  padding:3rem;
  text-align:center;
}

.empty-inner .big-globe{
  font-size:3rem;
  margin-bottom:1rem;
  display:block;
  opacity:0.4;
}

.empty-inner p{
  font-size:0.9rem;
  color:var(--muted);
  max-width:300px;
  margin:0 auto;
}

/* ─── BOTTOM NOTE ─── */
.bottom-note{
  max-width:960px;
  margin:0 auto;
  padding:0 1.5rem 3rem;
}

.note-inner{
  background:var(--gold-pale);
  border:1px solid rgba(168,131,58,0.25);
  border-radius:14px;
  padding:1.1rem 1.4rem;
  display:flex;
  align-items:flex-start;
  gap:0.8rem;
  font-size:0.85rem;
  color:var(--ink);
  line-height:1.5;
}

.note-icon{font-size:1.1rem;flex-shrink:0;margin-top:1px}

/* ─── RESPONSIVE ─── */
@media(max-width:640px){
  .hero{padding:2rem 1rem 1.5rem}
  .globe-deco{display:none}
  .section{padding:0 1rem 1rem}
  .detail-panel{padding:0 1rem}
  .detail-cards{grid-template-columns:1fr}
  .detail-card{border-right:none;border-bottom:1px solid var(--border)}
  .detail-card:last-child{border-bottom:none}
  .compare-grid{grid-template-columns:1fr}
  .detail-header{padding:1.25rem 1.25rem 1rem;flex-direction:column}
  .tags-row{padding:1rem 1.25rem}
  .compare-section{padding:1.25rem}
  .empty-state{padding:0 1rem}
  .bottom-note{padding:0 1rem 2rem}
}
</style>
</head>
