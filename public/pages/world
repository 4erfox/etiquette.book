// ── STATE ──
let activeId = null;

// ── RENDER GRID ──
function renderGrid(){
  const grid = document.getElementById('country-grid');
  grid.innerHTML = countries.map(c => `
    <div class="country-card${activeId===c.id?' active':''}" onclick="selectCountry('${c.id}')">
      <span class="flag">${c.flag}</span>
      <div class="c-name">${c.name}</div>
      <div class="c-sub">${c.sub}</div>
    </div>
  `).join('');
}

// ── SELECT COUNTRY ──
function selectCountry(id){
  if(activeId === id){
    activeId = null;
    document.getElementById('detail-panel').classList.remove('show');
    document.getElementById('empty-state').style.display='block';
    renderGrid();
    return;
  }
  activeId = id;
  renderGrid();
  const c = countries.find(x=>x.id===id);
  renderDetail(c);
  document.getElementById('empty-state').style.display='none';
  document.getElementById('detail-panel').classList.add('show');

  // scroll to panel
  setTimeout(()=>{
    document.getElementById('detail-panel').scrollIntoView({behavior:'smooth',block:'nearest'});
  },80);
}

// ── RENDER DETAIL ──
function renderDetail(c){
  const isKz = c.id === 'kz';

  const compareBlock = c.compare ? `
    <div class="compare-section">
      <div class="compare-title">
        <span class="kz-badge">🇰🇿</span>
        <h3>Казахстан vs ${c.name}: ключевые различия</h3>
      </div>
      <div class="compare-grid">
        ${c.compare.map(item=>`
          <div class="compare-item">
            <span class="ci-icon">${item.icon}</span>
            <div class="ci-text">
              <strong>${item.label}</strong>
              <span>🇰🇿 ${item.kz}</span><br>
              <span style="opacity:0.8">${c.flag} ${Object.values(item)[3]}</span>
            </div>
          </div>
        `).join('')}
      </div>
    </div>
  ` : (isKz ? `
    <div class="compare-section">
      <div class="compare-title">
